# Supabase PostgreSQL Connection
# Get these credentials from your Supabase project settings
SUPABASE_HOST=your-project.supabase.co
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your-database-password

# JWT Configuration
JWT_SECRET=your-super-secret-key-with-at-least-32-characters-long-for-hs256

# PayMongo (use sk_test_... for sandbox; never commit real keys)
PAYMONGO_SECRET_KEY=
# Where GCash/Maya redirects after payment (must match an allowed URL in PayMongo if configured)
APP_PAYMENT_RETURN_URL=http://localhost:3000/dashboard?payment=complete
